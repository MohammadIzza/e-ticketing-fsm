# Hanya untuk script admin lokal (TIDAK boleh di-commit, TIDAK boleh
# masuk bundle frontend). Salin ke `.env.admin.local` lalu isi.
#
# Dipakai oleh: npm run setup:superadmin

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Superadmin akan dibuat di Supabase Auth dengan email ini.
# UI tidak akan menampilkannya — user login pakai username.
SUPERADMIN_EMAIL=superadmin@fsm-lapor.local
SUPERADMIN_PASSWORD=kerasaktimigunani
SUPERADMIN_USERNAME=superrasyid
SUPERADMIN_FULL_NAME=Superadmin
