# Frontend env (committed bundle).
# Salin ke `.env.local` lalu isi nilainya.

VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# --- SSO Microsoft UNDIP ---
# Tenant ID UNDIP (sudah diisi, tidak perlu diubah kecuali berubah)
VITE_MICROSOFT_TENANT_ID=03290435-ff74-45d1-aeaa-173677221cf8

# Client ID dari App Registration di Azure Entra ID UNDIP
# Cara dapat:
#   1. Hubungi admin IT UNDIP / Direktorat TIK Undip
#   2. Minta mereka buat App Registration baru di portal.azure.com
#      (atau admin buka https://entra.microsoft.com > App registrations)
#   3. Isi Redirect URI: https://fsm-lapor.vercel.app/api/auth/microsoft-callback
#      (tipe: Web)
#   4. Aktifkan scope: openid, profile, email, User.Read
#   5. Salin Application (client) ID → isi di sini
VITE_MICROSOFT_CLIENT_ID=

# URL publik app (untuk membangun redirect_uri di SSO)
# Otomatis di-set dari VERCEL_URL di Vercel, tapi bisa di-override
VITE_APP_URL=https://fsm-lapor.vercel.app

# --- Server-side only (set di Vercel env vars, JANGAN di .env.local) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
APP_URL=https://fsm-lapor.vercel.app

# Client Secret dari App Registration (server-side only!)
# Cara dapat: Azure portal > App Registration > Certificates & secrets > New client secret
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=03290435-ff74-45d1-aeaa-173677221cf8
